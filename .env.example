# Bharat Ledger — environment configuration
# Copy this file to .env and fill in real values when ready to go live on GCP.
# Everything has a safe local default so the app runs fully offline with no cloud.

# ---- Google Cloud ----
GOOGLE_CLOUD_PROJECT=personal-hackthon-tests
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_GENAI_USE_VERTEXAI=1

# Set to true only after `gcloud auth application-default login` has been run
# and aiplatform/bigquery APIs are confirmed enabled. Default false = SQLite + mock-LLM.
USE_BIGQUERY=false
USE_VERTEX_AI=false

# ---- Models ----
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# ---- Document extraction ----
# Document AI is not enabled on the project yet — leave false to use the
# PyMuPDF + regex fallback extractor (pipeline/extract.py handles this transparently).
USE_DOCUMENT_AI=false
DOCUMENT_AI_PROCESSOR_ID=

# ---- Paths (relative to repo root, defaults shown) ----
SQLITE_PATH=data/bharat_ledger.sqlite
RAW_PDF_DIR=data/raw_pdfs
SYNTHETIC_DIR=data/synthetic
SEED_DIR=data/seed

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# ---- Demo flags ----
ENABLE_LIVE_DEBATE_ENDPOINT=true
