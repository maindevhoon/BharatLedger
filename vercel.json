{
  "builds": [
    { "src": "web/dist/**", "use": "@vercel/static" },
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/assets/(.*)", "dest": "/web/dist/assets/$1" },
    { "src": "/(.*)", "dest": "/web/dist/index.html" }
  ]
}
